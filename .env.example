# ============================================================
# ALPHA RADAR SIGNALS — Environment Configuration
# Copy this file to .env and fill in ALL required values.
# Lines marked [REQUIRED] will cause startup to FAIL if empty.
# ============================================================

# ─── Telegram ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                    # [REQUIRED] BotFather token
TELEGRAM_SIGNAL_CHAT_ID=               # Default public chat/channel ID
TELEGRAM_ADMIN_IDS=                    # Comma-separated Telegram user IDs

# Tier routing (optional — falls back to TELEGRAM_SIGNAL_CHAT_ID if unset)
PUBLIC_CHAT_ID=
VIP_CHAT_ID=
ELITE_VIP_CHAT_ID=

# ─── Binance Market Data ───────────────────────────────────
# Leave empty to use public REST (no API key needed for scanning).
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# ── 21F — Binance Futures TESTNET validation (separate keys, default off) ──
# Get keys at https://testnet.binancefuture.com (independent from production).
# The testnet preflight script refuses to run unless ENABLED + keys are set and
# the base URL is the testnet host. No mainnet order is ever possible from it.
BINANCE_TESTNET_ENABLED=false
BINANCE_TESTNET_BASE_URL=https://testnet.binancefuture.com
BINANCE_TESTNET_WS_URL=wss://stream.binancefuture.com/ws
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# ─── PostgreSQL Database ───────────────────────────────────
POSTGRES_USER=signals
POSTGRES_PASSWORD=change_this_postgres_password   # [REQUIRED in production]
POSTGRES_DB=signals
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Scanner / Signal Engine ──────────────────────────────
UNIVERSE_REFRESH_SEC=900
SCAN_INTERVAL_SEC=30
SCAN_TIMEFRAMES=15m,1h,4h,1d
MAX_SYMBOLS=0
MIN_QUOTE_VOLUME_USDT=5000000
MIN_CONFIDENCE=82
MIN_RR=2.2
SIGNAL_COOLDOWN_SEC=3600
SYMBOL_COOLDOWN_MINUTES=30
ANTI_DUPLICATE_SIGNAL=true
MAX_SIGNALS_PER_HOUR=3

# ── Regime Adaptive Gate V1 (feature-flagged; default OFF) ──
# Adapts RR / SL-distance / confidence thresholds to the market regime so range/
# low-volatility markets are not blanket-rejected. Never forces emission; hard
# clamps: min_rr>=1.0, max_sl_distance<=20.0, min_confidence>=70.
REGIME_ADAPTIVE_GATE_ENABLED=false
NORMAL_MIN_RR=1.5
NORMAL_MAX_SL_DISTANCE_PERCENT=10.0
NORMAL_MIN_CONFIDENCE_DELTA=0
LOW_VOL_MIN_RR=1.0
LOW_VOL_MAX_SL_DISTANCE_PERCENT=15.0
LOW_VOL_MIN_CONFIDENCE_DELTA=-3
HIGH_VOL_MIN_RR=1.8
HIGH_VOL_MAX_SL_DISTANCE_PERCENT=8.0
HIGH_VOL_MIN_CONFIDENCE_DELTA=3
BULL_MIN_RR=1.3
BULL_MAX_SL_DISTANCE_PERCENT=12.0
BULL_MIN_CONFIDENCE_DELTA=-2
BEAR_MIN_RR=1.3
BEAR_MAX_SL_DISTANCE_PERCENT=12.0
BEAR_MIN_CONFIDENCE_DELTA=-2
SIDEWAYS_MIN_RR=1.6
SIDEWAYS_MAX_SL_DISTANCE_PERCENT=8.0
SIDEWAYS_MIN_CONFIDENCE_DELTA=3

# ══════════════════════════════════════════════════════════════════
#  SPRINT 22 — Institutional Risk & Execution Upgrade (all default OFF)
#  Every engine is feature-flagged; off == identical prior behaviour.
#  None place real orders; shadow mode never touches the exchange.
# ══════════════════════════════════════════════════════════════════

# ── 22A — Portfolio Exposure + Position Lock ──
PORTFOLIO_EXPOSURE_ENGINE_ENABLED=false
MAX_OPEN_POSITIONS_PER_USER=5
MAX_SAME_DIRECTION_POSITIONS=3
MAX_CORRELATED_POSITIONS=2
MAX_DAILY_LOSS_PERCENT=5
SYMBOL_LOCK_ENABLED=true
PENDING_ORDER_LOCK_ENABLED=true
CORRELATION_GROUPS=BTC:ETH,SOL,DOGE,AVAX;AI:FET,AGIX,OCEAN;MEME:DOGE,SHIB,PEPE

# ── 22B — Signal Explainability ──
SIGNAL_EXPLAINABILITY_ENABLED=false

# ── 22C — Trade Lifecycle Analytics ──
TRADE_LIFECYCLE_ANALYTICS_ENABLED=false

# ── 22D — Break-Even + Partial TP (reduce-only; never widens SL) ──
BREAK_EVEN_ENGINE_ENABLED=false
PARTIAL_TP_PERCENT=40
MOVE_SL_TO_ENTRY_ON_TP1=true
TRAILING_STOP_ENABLED=true
TRAILING_STOP_DISTANCE_PERCENT=1.5

# ── 22E — News / Event Risk Filter ──
NEWS_EVENT_FILTER_ENABLED=false
PRE_EVENT_BLOCK_MINUTES=60
POST_EVENT_BLOCK_MINUTES=30
HIGH_IMPACT_EVENTS=CPI,FOMC,NFP,FED

# ── 22F — Liquidity Map V2 ──
LIQUIDITY_MAP_V2_ENABLED=false

# ── 22G — Shadow Mode Live Validation (NEVER places real orders) ──
SHADOW_MODE_ENABLED=false
SHADOW_MODE_SLIPPAGE_BPS=5.0
SHADOW_MODE_LATENCY_MS=250.0

# ─── Dashboard / Admin ────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8010
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=                    # [REQUIRED] Strong password — startup fails if empty
SECRET_KEY=                            # [REQUIRED] Random secret for sessions — startup fails if empty
PRODUCTION_START_UTC=                  # e.g. 2026-05-01 00:00:00

# ─── Public Community Links ───────────────────────────────
TELEGRAM_CHANNEL_URL=
DISCORD_URL=

# ─── Donations ────────────────────────────────────────────
DONATE_USDT_TRC20=
DONATE_USDT_BEP20=
DONATE_BTC=
DONATE_ETH=

# ─── Affiliate Links ──────────────────────────────────────
BINANCE_AFFILIATE_URL=
BYBIT_AFFILIATE_URL=
OKX_AFFILIATE_URL=
BITGET_AFFILIATE_URL=

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=/app/logs
LOG_REJECTION_DETAIL=false
LOG_RETENTION_DAYS=30
LOG_MAX_SIZE_MB=100

# ─── Telegram Tier Routing Thresholds ─────────────────────
PUBLIC_MIN_CONFIDENCE=82
VIP_MIN_CONFIDENCE=85
ELITE_MIN_CONFIDENCE=95
ELITE_MIN_RR=2.5
HIGH_PRIORITY_CONFIDENCE=97
HIGH_PRIORITY_RR=3.5

# ─── Paper Trading (Phase 7) ──────────────────────────────
PAPER_TRADING=false
PAPER_INITIAL_BALANCE=10000.0
PAPER_RISK_PER_TRADE_PCT=1.0

# ─── Auto Trading Foundation (Phase 13) ── NOT ENABLED ───
# AUTO_TRADING_ENABLED is hard-locked to false — do NOT change
AUTO_TRADING_ENABLED=false
AUTO_TRADING_MAX_POSITION_PCT=2.0
AUTO_TRADING_DAILY_LOSS_LIMIT_PCT=5.0

# ─── Sprint 20A: Auth / User Accounts (SaaS) ──────────────
# Multi-user auth API (/api/auth/*) is mounted only when AUTH_ENABLED=true.
AUTH_ENABLED=false
JWT_SECRET=                            # blank -> falls back to SECRET_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=30
REFRESH_TOKEN_TTL_DAYS=14
BCRYPT_ROUNDS=12
EMAIL_VERIFICATION_REQUIRED=true
ACCOUNT_LOCKOUT_THRESHOLD=5            # failed logins before temporary lock
ACCOUNT_LOCKOUT_MINUTES=15
APP_BASE_URL=http://localhost:8010
AUTH_ISSUER=Alpha Radar Signals

# ── P11 — Google OAuth login (feature-flagged; default off) ──
# Create an OAuth 2.0 Client ID (type: Web application) in Google Cloud Console,
# add the redirect URI below to "Authorized redirect URIs", then set these.
# Leave GOOGLE_OAUTH_ENABLED=false until the credentials are filled in.
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=                    # e.g. http://localhost:8010/api/auth/google/callback
OAUTH_SUCCESS_REDIRECT=/app#/dashboard
OAUTH_FAILURE_REDIRECT=/login?error=oauth_failed
# SMTP — if SMTP_HOST is blank, verification/reset emails are LOGGED, not sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@alpharadar.local
SMTP_TLS=true

# ─── Sprint 20B: Per-user Paper Trading (SaaS, demo only) ──
# Mounts the per-user paper-trading API (/api/paper/account/*). Requires a 20A
# auth token to use. Distinct from the legacy global PAPER_TRADING flag above.
PAPER_TRADING_ENABLED=true
DEFAULT_DEMO_BALANCE=10000              # starting virtual balance per paper account

# ─── Sprint 20C: Exchange API Vault ───────────────────────
# Encrypted per-user exchange credentials. Withdrawal-enabled keys are rejected.
EXCHANGE_API_VAULT_ENABLED=true
# Adapters simulate validation/fills when true (no real network/orders).
MOCK_EXCHANGE_MODE=true
# AES-256 master key for the vault. Blank -> derived from SECRET_KEY.
# Rotating this invalidates all stored exchange keys.
VAULT_MASTER_KEY=
DEFAULT_DEMO_BALANCE=10000

# ─── Live Trading Master Safety Gate (Sprint 20D-20G) ─────
# Global kill switch for REAL order execution. All exchange adapters run in
# MOCK mode by default and place NO real orders unless this is explicitly true,
# even when a user has connected valid API keys. Keep false until paper
# trading + safety layer + API vault are fully validated.
LIVE_TRADING_ENABLED=false
# Sprint 20F — expose the /api/live endpoints (usable in MOCK). Exposing the
# API does NOT enable real orders; that still needs LIVE_TRADING_ENABLED=true
# AND MOCK_EXCHANGE_MODE=false. Keep the API off in production until validated.
LIVE_TRADING_API_ENABLED=false

# ─── Live Pilot — tiny gated Binance-only live run (default OFF) ───
# Never auto-executes. A real order also requires the live execution gate
# (LIVE_TRADING_ENABLED=true AND MOCK_EXCHANGE_MODE=false) plus the manual
# confirmation phrase "I UNDERSTAND THIS PLACES A REAL ORDER" and all safety
# checks. Use a Binance key with trade permission, withdrawal DISABLED.
LIVE_PILOT_ENABLED=false
LIVE_PILOT_USER_ID=
LIVE_PILOT_MAX_NOTIONAL=50
LIVE_PILOT_MAX_POSITIONS=2
LIVE_PILOT_MAX_LEVERAGE=3
LIVE_PILOT_ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT
LIVE_PILOT_REQUIRE_CONFIRMATION=true

# ─── Multi-user Live Beta — controlled live access (default OFF) ───
# Mounts /api/live-beta/* and enforces per-user/per-symbol/global exposure caps
# in the live open path. Still requires the live execution gate for real orders.
LIVE_BETA_ENABLED=false
LIVE_BETA_MAX_USERS=10
LIVE_BETA_REQUIRE_ADMIN_APPROVAL=true
LIVE_BETA_INVITE_CODE=                  # if set, required to request access
LIVE_BETA_GLOBAL_MAX_NOTIONAL=500
LIVE_BETA_DEFAULT_USER_MAX_NOTIONAL=100
LIVE_BETA_DEFAULT_MAX_POSITIONS=2
LIVE_BETA_PER_SYMBOL_MAX_NOTIONAL=100
LIVE_BETA_ALLOWED_EXCHANGES=binance

# ─── Sprint 20D: Auto Trading Engine (DEMO ONLY, paper accounts) ───
# Global gate for the demo auto-trader. Per-user opt-in is the /api/auto config
# (enabled) or the paper account's auto-follow toggle. Never places real orders.
AUTO_TRADE_DEMO_ENABLED=false

# ─── Sprint 20E: Real Trading Safety Layer ────────────────
# Account-protection guards wrap every auto open: daily/weekly loss limits,
# max open + correlated positions, trade cooldown, loss-streak lockout, and
# user/admin kill switches. On by default; per-user limits via /api/safety.
SAFETY_LAYER_ENABLED=true

# ─── Sprint 20H: Admin Dashboard ──────────────────────────
# ADMIN-only platform oversight API (/api/admin/*): overview rollup, user
# list/detail, live audit feed, suspend/activate. Read-oriented; never exposes
# decrypted credentials. Requires AUTH_ENABLED and an ADMIN-role user. Default off.
ADMIN_DASHBOARD_ENABLED=false

# ─── Funding Rate Engine (Sprint 11B) ─────────────────────
FUNDING_ENABLED=true
FUNDING_CACHE_SECONDS=300
FUNDING_POSITIVE=0.0003
FUNDING_NEGATIVE=-0.0003
FUNDING_EXTREME_POSITIVE=0.0008
FUNDING_EXTREME_NEGATIVE=-0.0008
FUNDING_WEIGHT=10

# ─── Timezone ─────────────────────────────────────────────
TZ=UTC
TIMEZONE=UTC
ENTRY_PASS_SCORE=2

# ─── Monitoring (Prometheus + Grafana overlay; opt-in compose file) ───
# Used by docker-compose.monitoring.yml. Grafana is bound to localhost only;
# put it behind the reverse proxy before exposing. CHANGE the password.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-env

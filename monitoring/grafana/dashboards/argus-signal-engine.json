{
  "uid": "argus-signal-engine",
  "title": "3. Signal Engine",
  "tags": [
    "argus-quant"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Universe size",
      "datasource": {
        "type": "prometheus",
        "uid": "argus-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "alpha_radar_universe_size",
          "datasource": {
            "type": "prometheus",
            "uid": "argus-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total MTF signals",
      "datasource": {
        "type": "prometheus",
        "uid": "argus-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "alpha_radar_signals_total",
          "datasource": {
            "type": "prometheus",
            "uid": "argus-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "WS feed OK",
      "datasource": {
        "type": "prometheus",
        "uid": "argus-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "alpha_radar_ws_ok",
          "datasource": {
            "type": "prometheus",
            "uid": "argus-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Signals recorded (rate/h)",
      "datasource": {
        "type": "prometheus",
        "uid": "argus-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(alpha_radar_signals_total[1h]) * 3600",
          "datasource": {
            "type": "prometheus",
            "uid": "argus-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    }
  ]
}
{
  "uid": "argus-system-health",
  "title": "1. System Health",
  "tags": [
    "argus-quant"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "DB up",
      "datasource": {
        "type": "prometheus",
        "uid": "argus-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "alpha_radar_db_up",
          "datasource": {
            "type": "prometheus",
            "uid": "argus-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Redis up",
      "datasource": {
        "type": "prometheus",
        "uid": "argus-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "alpha_radar_redis_up",
          "datasource": {
            "type": "prometheus",
            "uid": "argus-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "WS feed OK",
      "datasource": {
        "type": "prometheus",
        "uid": "argus-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "alpha_radar_ws_ok",
          "datasource": {
            "type": "prometheus",
            "uid": "argus-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Uptime (s)",
      "datasource": {
        "type": "prometheus",
        "uid": "argus-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "alpha_radar_uptime_seconds",
          "datasource": {
            "type": "prometheus",
            "uid": "argus-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP requests/min by status",
      "datasource": {
        "type": "prometheus",
        "uid": "argus-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(alpha_radar_http_requests_total[5m])) * 60",
          "datasource": {
            "type": "prometheus",
            "uid": "argus-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP 5xx errors (rate)",
      "datasource": {
        "type": "prometheus",
        "uid": "argus-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(alpha_radar_http_request_errors_total[5m])",
          "datasource": {
            "type": "prometheus",
            "uid": "argus-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "WS reconnect attempts",
      "datasource": {
        "type": "prometheus",
        "uid": "argus-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "alpha_radar_ws_reconnects_total",
          "datasource": {
            "type": "prometheus",
            "uid": "argus-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Avg request latency (ms)",
      "datasource": {
        "type": "prometheus",
        "uid": "argus-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(alpha_radar_http_request_duration_seconds_sum[5m]) / clamp_min(rate(alpha_radar_http_request_duration_seconds_count[5m]),1) * 1000",
          "datasource": {
            "type": "prometheus",
            "uid": "argus-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {}
    }
  ]
}